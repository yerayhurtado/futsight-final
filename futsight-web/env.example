# Base URL del agente de scouting (sin barra final).
# La web llama a POST {AGENT_API_URL}/buscar y GET {AGENT_API_URL}/jugadores?ids=...
# En local, usa 127.0.0.1 para evitar problemas de resolución con localhost:
#   AGENT_API_URL=http://127.0.0.1:8000
# Producción: https://tu-agente.up.railway.app
AGENT_API_URL=
# Alternativamente:
# LANGGRAPH_AGENT_URL=
