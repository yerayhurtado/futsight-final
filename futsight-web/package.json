{
  "name": "fronted-futsight",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:front": "next dev",
    "dev:back": "cd prediction-service && uvicorn main:app --port 8001 --reload",
    "dev:agent": "cd ../futsigh_agent && cross-env PYTHONIOENCODING=utf8 venv\\Scripts\\python.exe -m uvicorn api:app --host 0.0.0.0 --port 8000 --reload",
    "dev:all": "concurrently \"npm run dev:front\" \"npm run dev:back\" \"npm run dev:agent\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.555.0",
    "next": "^16.0.10",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
